---
import Layout from '../components/Layout.astro';
import CafeCard from '../components/CafeCard';
import { Button } from '../components/ui/button';
import { Input } from '../components/ui/input';
import { Badge } from '../components/ui/badge';
import { cafes, cities, types } from '../data/cafes';
---

<Layout>
  <!-- Header -->
  <section className="bg-gradient-to-br from-primary to-ocean py-12">
    <div className="container mx-auto px-4">
      <div className="max-w-3xl mx-auto text-center space-y-4">
        <h1 className="text-3xl md:text-5xl font-bold text-white">
          Explorer les Cafes
        </h1>
        <p className="text-lg text-white/90">
          Trouvez votre prochain espace de travail ideal parmi {cafes.length} cafes selectionnes.
        </p>
      </div>
    </div>
  </section>

  <!-- Search & Filters -->
  <section className="sticky top-16 z-40 bg-background/95 backdrop-blur border-b py-6">
    <div className="container mx-auto px-4">
      <div className="space-y-4">
        <!-- Search Bar -->
        <div className="relative max-w-2xl mx-auto">
          <input
            type="text"
            placeholder="Rechercher par nom ou quartier..."
            className="flex h-12 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          />
        </div>

        <!-- Filter Buttons -->
        <div className="flex flex-wrap gap-4 justify-center">
          <!-- City Filters -->
          <div className="flex items-center gap-2">
            <span className="text-sm font-medium">Ville:</span>
            <Button variant="outline" size="sm">Toutes</Button>
            {cities.map((city) => (
              <Button key={city} variant="outline" size="sm">{city}</Button>
            ))}
          </div>

          <!-- Type Filters -->
          <div className="flex items-center gap-2">
            <span className="text-sm font-medium">Type:</span>
            <Button variant="outline" size="sm">Tous</Button>
            {Object.entries(types).map(([key, label]) => (
              <Button key={key} variant="outline" size="sm">{label}</Button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section className="py-12">
    <div className="container mx-auto px-4">
      <div className="mb-6">
        <p className="text-muted-foreground">
          {cafes.length} cafe{cafes.length !== 1 ? "s" : ""} trouve{cafes.length !== 1 ? "s" : ""}
        </p>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {cafes.map((cafe) => (
          <CafeCard key={cafe.id} cafe={cafe} client:load />
        ))}
      </div>
    </div>
  </section>
</Layout>
