---
import Layout from '../layouts/Layout.astro';
import CafeCard from '../components/CafeCard';
import { cafes, cities, types } from '../data/cafes';
---

<Layout title="Explorer les Cafés - CaféNomad Sénégal">
  <div class="min-h-screen flex flex-col">
    <!-- Navbar -->
    <nav class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
      <div class="container mx-auto px-4">
        <div class="flex h-16 items-center justify-between">
          <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-80">
            <img src="/logo.jpg" alt="CaféNomad" class="h-10 w-10 rounded-full object-cover" />
            <span class="text-xl font-bold bg-gradient-to-r from-primary to-ocean bg-clip-text text-transparent">
              CaféNomad
            </span>
          </a>

          <div class="hidden md:flex items-center gap-6">
            <a href="/" class="text-sm font-medium text-foreground hover:text-primary transition-colors">Accueil</a>
            <a href="/cafes" class="text-sm font-medium text-foreground hover:text-primary transition-colors">Explorer</a>
            <a href="/about" class="text-sm font-medium text-foreground hover:text-primary transition-colors">À Propos</a>
          </div>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <!-- Header -->
      <section class="bg-gradient-to-br from-primary via-ocean to-secondary py-12">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl mx-auto text-center space-y-4">
            <h1 class="text-3xl md:text-5xl font-bold text-white">
              Explorer les Cafés
            </h1>
            <p class="text-lg text-white/90">
              Trouvez votre prochain espace de travail idéal parmi {cafes.length} cafés sélectionnés.
            </p>
          </div>
        </div>
      </section>

      <!-- Search & Filters -->
      <section class="sticky top-16 z-40 bg-background/95 backdrop-blur border-b py-6">
        <div class="container mx-auto px-4">
          <div class="space-y-4">
            <!-- Search Bar -->
            <div class="relative max-w-2xl mx-auto">
              <input
                type="text"
                placeholder="Rechercher par nom ou quartier..."
                class="flex h-12 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
              />
            </div>

            <!-- Filter Buttons -->
            <div class="flex flex-wrap gap-4 justify-center">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium">Ville:</span>
                <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3">Toutes</button>
                {cities.map((city) => (
                  <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3">{city}</button>
                ))}
              </div>

              <div class="flex items-center gap-2">
                <span class="text-sm font-medium">Type:</span>
                <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3">Tous</button>
                {Object.entries(types).map(([key, label]) => (
                  <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-3">{label}</button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Results -->
      <section class="py-12">
        <div class="container mx-auto px-4">
          <div class="mb-6">
            <p class="text-muted-foreground">
              {cafes.length} café{cafes.length !== 1 ? "s" : ""} trouvé{cafes.length !== 1 ? "s" : ""}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {cafes.map((cafe) => (
              <CafeCard cafe={cafe} client:load />
            ))}
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-t bg-secondary text-secondary-foreground">
      <div class="container mx-auto px-4 py-8">
        <div class="text-center text-sm">
          <p class="flex items-center justify-center gap-1">
            Fait avec <span class="text-primary">♥</span> pour les nomades digitaux du Sénégal
          </p>
          <p class="mt-2 text-secondary-foreground/60">© 2026 CaféNomad Sénégal</p>
        </div>
      </div>
    </footer>
  </div>
</Layout>
