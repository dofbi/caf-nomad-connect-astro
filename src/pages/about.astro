---
import Layout from '../components/Layout.astro';
import { Card, CardContent } from '../components/ui/card';
---

<Layout>
  <!-- Header -->
  <section className="bg-gradient-hero py-16">
    <div className="container mx-auto px-4">
      <div className="max-w-3xl mx-auto text-center space-y-4">
        <h1 className="text-3xl md:text-5xl font-bold text-white">
          À Propos de CaféNomad
        </h1>
        <p className="text-lg text-white/90">
          Votre compagnon pour trouver les meilleurs espaces de travail au Sénégal
        </p>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section className="py-20 bg-background">
    <div className="container mx-auto px-4">
      <div className="max-w-3xl mx-auto space-y-8">
        <h2 className="text-3xl font-bold text-center mb-8">Notre Mission</h2>
        
        <p className="text-lg text-muted-foreground leading-relaxed">
          CaféNomad est né d'une simple observation : au Sénégal, les espaces de travail abordables sont difficiles à trouver, tandis que les coworkings traditionnels sont souvent trop chers pour les freelances, étudiants et nomades digitaux.
        </p>
        
        <p className="text-lg text-muted-foreground leading-relaxed">
          Notre mission est de connecter les travailleurs indépendants avec des cafés idéaux pour travailler, en évaluant chaque espace selon des critères importants : qualité du WiFi, disponibilité des prises, ambiance et rapport qualité-prix.
        </p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section className="py-20 bg-muted/30">
    <div className="container mx-auto px-4">
      <h2 className="text-3xl font-bold text-center mb-12">Pourquoi Nous Faire Confiance ?</h2>
      
      <div className="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <Card>
          <CardContent className="p-6 text-center space-y-4">
            <div className="w-16 h-16 mx-auto bg-primary/10 rounded-full flex items-center justify-center">
              <svg className="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 className="text-xl font-semibold">Évaluations Objectives</h3>
            <p className="text-muted-foreground">
              Chaque café est évalué selon des critères précis par notre équipe et la communauté.
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="p-6 text-center space-y-4">
            <div className="w-16 h-16 mx-auto bg-primary/10 rounded-full flex items-center justify-center">
              <svg className="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 className="text-xl font-semibold">Présence Locale</h3>
            <p className="text-muted-foreground">
              Une connaissance approfondie du terrain au Sénégal avec des recommandations sur mesure.
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="p-6 text-center space-y-4">
            <div className="w-16 h-16 mx-auto bg-primary/10 rounded-full flex items-center justify-center">
              <svg className="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <h3 className="text-xl font-semibold">Communauté Active</h3>
            <p className="text-muted-foreground">
              Rejoignez notre réseau de professionnels et partagez vos expériences.
            </p>
          </CardContent>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section className="py-20 bg-gradient-hero">
    <div className="container mx-auto px-4 text-center">
      <div className="max-w-2xl mx-auto space-y-6">
        <h2 className="text-3xl md:text-4xl font-bold text-white">
          Rejoignez la Communauté
        </h2>
        <p className="text-lg text-white/90">
          Découvrez votre prochain spot de travail préféré et connectez-vous avec d'autres nomades digitaux.
        </p>
        <a 
          href="/cafes" 
          className="inline-flex items-center justify-center rounded-lg bg-white text-primary px-8 py-3 text-base font-medium shadow-soft hover:bg-white/90 transition-colors"
        >
          Explorer les Cafés
          <span className="ml-2">→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
