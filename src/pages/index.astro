---
import Layout from '../components/Layout';
import CafeCard from '../components/CafeCard';
import { Button } from '../components/ui/button';
import { cafes } from '../data/cafes';

const featuredCafes = cafes.filter(c => c.label === "Platinum" || c.label === "Gold").slice(0, 3);
---

<Layout>
  <!-- Hero Section -->
  <section className="relative overflow-hidden bg-gradient-to-br from-[hsl(210,60%,45%)] to-[hsl(190,60%,35%)] py-20 md:py-32">
    <div className="container mx-auto px-4 relative z-10">
      <div className="max-w-3xl mx-auto text-center space-y-8">
        <h1 className="text-4xl md:text-6xl font-bold text-white leading-tight">
          Travaillez Librement dans les Meilleurs Cafes du Senegal
        </h1>
        <p className="text-lg md:text-xl text-white/90 leading-relaxed">
          CafeNomad vous aide a trouver des espaces abordables et inspirants pour travailler, 
          etudier et connecter avec d'autres nomades digitaux a Dakar et Thies.
        </p>
        <div className="flex flex-col sm:flex-row gap-4 justify-center">
          <Button asChild size="lg" className="bg-white text-[hsl(210,60%,45%)] hover:bg-white/90 shadow-soft text-base px-8">
            <a href="/cafes">
              Explorer les Cafes
              <span className="ml-2">→</span>
            </a>
          </Button>
          <Button asChild size="lg" variant="outline" className="bg-white/10 text-white border-white/30 hover:bg-white/20 text-base px-8">
            <a href="/about">En Savoir Plus</a>
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section className="py-20 bg-background">
    <div className="container mx-auto px-4">
      <div className="text-center mb-12">
        <h2 className="text-3xl md:text-4xl font-bold mb-4">Pourquoi CafeNomad ?</h2>
        <p className="text-muted-foreground max-w-2xl mx-auto">
          Une alternative abordable aux coworkings chers, avec la flexibilite et la diversite en plus.
        </p>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div className="text-center space-y-4 p-6 rounded-lg bg-gradient-to-br from-white to-slate-50 shadow-soft hover:shadow-card transition-all">
          <div className="w-14 h-14 mx-auto bg-[hsl(210,60%,45%)]/10 rounded-full flex items-center justify-center">
            <svg className="h-7 w-7 text-[hsl(210,60%,45%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" />
            </svg>
          </div>
          <h3 className="text-xl font-semibold">WiFi & Prises Fiables</h3>
          <p className="text-muted-foreground">
            Tous les cafes sont notes sur la qualite du WiFi et la disponibilite des prises electriques.
          </p>
        </div>

        <div className="text-center space-y-4 p-6 rounded-lg bg-gradient-to-br from-white to-slate-50 shadow-soft hover:shadow-card transition-all">
          <div className="w-14 h-14 mx-auto bg-[hsl(210,60%,60%)]/10 rounded-full flex items-center justify-center">
            <svg className="h-7 w-7 text-[hsl(210,60%,60%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 className="text-xl font-semibold">Budget Etudiant</h3>
          <p className="text-muted-foreground">
            Des options abordables a partir de 1500FCFA, sans abonnement mensuel cher.
          </p>
        </div>

        <div className="text-center space-y-4 p-6 rounded-lg bg-gradient-to-br from-white to-slate-50 shadow-soft hover:shadow-card transition-all">
          <div className="w-14 h-14 mx-auto bg-[hsl(210,40%,96%)]/10 rounded-full flex items-center justify-center">
            <svg className="h-7 w-7 text-[hsl(210,40%,46%)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h3 className="text-xl font-semibold">Communaute Active</h3>
          <p className="text-muted-foreground">
            Rencontrez d'autres freelances, etudiants et creatifs. Participez aux meetups tech.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Cafes -->
  <section className="py-20 bg-muted/30">
    <div className="container mx-auto px-4">
      <div className="text-center mb-12">
        <h2 className="text-3xl md:text-4xl font-bold mb-4">Cafes en Vedette</h2>
        <p className="text-muted-foreground">
          Decouvrez nos spots les mieux notes par la communaute nomade.
        </p>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        {featuredCafes.map((cafe) => (
          <CafeCard key={cafe.id} cafe={cafe} client:load />
        ))}
      </div>

      <div className="text-center">
        <Button asChild size="lg" className="bg-gradient-to-br from-[hsl(210,60%,45%)] to-[hsl(190,60%,35%)] text-white shadow-soft">
          <a href="/cafes">
            Voir Tous les Cafes
            <span className="ml-2">→</span>
          </a>
        </Button>
      </div>
    </div>
  </section>

  <!-- Labels Section -->
  <section className="py-20 bg-background">
    <div className="container mx-auto px-4">
      <div className="text-center mb-12">
        <h2 className="text-3xl md:text-4xl font-bold mb-4">Systeme de Labels</h2>
        <p className="text-muted-foreground max-w-2xl mx-auto">
          Chaque cafe est evalue selon des criteres stricts pour garantir la meilleure experience nomade.
        </p>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div className="text-center p-6 rounded-lg border-2 border-border bg-card">
          <div className="text-3xl mb-3">🥉</div>
          <h3 className="font-semibold mb-2">Bronze</h3>
          <p className="text-sm text-muted-foreground">WiFi & Prises Basics</p>
        </div>

        <div className="text-center p-6 rounded-lg border-2 border-border bg-card">
          <div className="text-3xl mb-3">🥈</div>
          <h3 className="font-semibold mb-2">Silver</h3>
          <p className="text-sm text-muted-foreground">Horaire Etendus</p>
        </div>

        <div className="text-center p-6 rounded-lg border-2 border-border bg-card">
          <div className="text-3xl mb-3">🥇</div>
          <h3 className="font-semibold mb-2">Gold</h3>
          <p className="text-sm text-muted-foreground">Excellence Nomade</p>
        </div>

        <div className="text-center p-6 rounded-lg border-2 border-[hsl(210,60%,45%)] bg-[hsl(210,60%,45%)]/5">
          <div className="text-3xl mb-3">💎</div>
          <h3 className="font-semibold mb-2">Platinum</h3>
          <p className="text-sm text-muted-foreground">Premium + Events</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section className="py-20 bg-gradient-to-br from-[hsl(210,60%,45%)] to-[hsl(190,60%,35%)] relative overflow-hidden">
    <div className="container mx-auto px-4 text-center relative z-10">
      <div className="max-w-2xl mx-auto space-y-6">
        <h2 className="text-3xl md:text-4xl font-bold text-white">
          Pret a Rejoindre la Communaute ?
        </h2>
        <p className="text-lg text-white/90">
          Decouvrez votre prochain spot de travail prefere et connectez-vous avec des nomades digitaux du Senegal.
        </p>
        <Button
          asChild
          size="lg"
          className="bg-white text-[hsl(210,60%,45%)] hover:bg-white/90 shadow-soft text-base px-8"
        >
          <a href="/cafes">
            Commencer Maintenant
            <span className="ml-2">⚡</span>
          </a>
        </Button>
      </div>
    </div>
  </section>
</Layout>
