---
import Layout from '../layouts/Layout.astro';
import CafeCard from '../components/CafeCard';
import { Button } from '../components/ui/button';
import { cafes } from '../data/cafes';
import { ArrowRight, Wifi, MapPin, Users, Zap } from 'lucide-react';

const featuredCafes = cafes.filter(c => c.label === "Platinum" || c.label === "Gold").slice(0, 3);
---

<Layout title="CaféNomad Sénégal - Travaillez dans les meilleurs cafés">
  <div class="min-h-screen flex flex-col">
    <!-- Navbar -->
    <nav class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
      <div class="container mx-auto px-4">
        <div class="flex h-16 items-center justify-between">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-80">
            <span class="text-3xl">☕</span>
            <span class="text-xl font-bold bg-gradient-to-r from-primary to-ocean bg-clip-text text-transparent">
              CaféNomad
            </span>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-6">
            <a href="/" class="text-sm font-medium text-foreground hover:text-primary transition-colors">
              Accueil
            </a>
            <a href="/cafes" class="text-sm font-medium text-foreground hover:text-primary transition-colors">
              Explorer
            </a>
            <a href="/about" class="text-sm font-medium text-foreground hover:text-primary transition-colors">
              À Propos
            </a>
            <a href="#" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-gradient-to-r from-primary to-ocean text-white shadow-soft hover:shadow-card transition-all h-10 px-4 py-2">
              Rejoindre
            </a>
          </div>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <!-- Hero Section -->
      <section class="relative overflow-hidden bg-gradient-to-br from-primary via-ocean to-secondary py-20 md:py-32">
        <div class="absolute inset-0 bg-[url('/pattern.svg')] opacity-10"></div>
        <div class="container mx-auto px-4 relative z-10">
          <div class="max-w-3xl mx-auto text-center space-y-8">
            <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight">
              Travaillez Librement dans les Meilleurs Cafés du Sénégal
            </h1>
            <p class="text-lg md:text-xl text-white/90 leading-relaxed">
              CaféNomad vous aide à trouver des espaces abordables et inspirants pour travailler, 
              étudier et connecter avec d'autres nomades digitaux à Dakar et Thiès.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/cafes" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-white text-primary hover:bg-white/90 shadow-soft h-11 px-8 text-base">
                Explorer les Cafés <ArrowRight className="ml-2 h-5 w-5" />
              </a>
              <a href="/about" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-white/10 text-white border border-white/30 hover:bg-white/20 h-11 px-8 text-base">
                En Savoir Plus
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Features Section -->
      <section class="py-20 bg-background">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold mb-4">Pourquoi CaféNomad ?</h2>
            <p class="text-muted-foreground max-w-2xl mx-auto">
              Une alternative abordable aux coworkings chers, avec la flexibilité et la diversité en plus.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="text-center space-y-4 p-6 rounded-lg bg-gradient-to-br from-card to-background shadow-soft hover:shadow-card transition-all border">
              <div class="w-14 h-14 mx-auto bg-primary/10 rounded-full flex items-center justify-center">
                <Wifi class="h-7 w-7 text-primary" />
              </div>
              <h3 class="text-xl font-semibold">WiFi & Prises Fiables</h3>
              <p class="text-muted-foreground">
                Tous les cafés sont notés sur la qualité du WiFi et la disponibilité des prises électriques.
              </p>
            </div>

            <div class="text-center space-y-4 p-6 rounded-lg bg-gradient-to-br from-card to-background shadow-soft hover:shadow-card transition-all border">
              <div class="w-14 h-14 mx-auto bg-ocean/10 rounded-full flex items-center justify-center">
                <MapPin class="h-7 w-7 text-ocean" />
              </div>
              <h3 class="text-xl font-semibold">Budget Étudiant</h3>
              <p class="text-muted-foreground">
                Des options abordables à partir de 1500 FCFA, sans abonnement mensuel coûteux.
              </p>
            </div>

            <div class="text-center space-y-4 p-6 rounded-lg bg-gradient-to-br from-card to-background shadow-soft hover:shadow-card transition-all border">
              <div class="w-14 h-14 mx-auto bg-secondary/10 rounded-full flex items-center justify-center">
                <Users class="h-7 w-7 text-secondary" />
              </div>
              <h3 class="text-xl font-semibold">Communauté Active</h3>
              <p class="text-muted-foreground">
                Rencontrez d'autres freelances, étudiants et créatifs. Participez aux meetups tech.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Featured Cafes -->
      <section class="py-20 bg-muted/30">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold mb-4">Cafés en Vedette</h2>
            <p class="text-muted-foreground">
              Découvrez nos spots les mieux notés par la communauté nomade.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            {featuredCafes.map((cafe) => (
              <CafeCard cafe={cafe} client:load />
            ))}
          </div>

          <div class="text-center">
            <a href="/cafes" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-gradient-to-r from-primary to-ocean text-white shadow-soft h-11 px-8">
              Voir Tous les Cafés <ArrowRight class="ml-2 h-5 w-5" />
            </a>
          </div>
        </div>
      </section>

      <!-- Labels Section -->
      <section class="py-20 bg-background">
        <div class="container mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold mb-4">Système de Labels</h2>
            <p class="text-muted-foreground max-w-2xl mx-auto">
              Chaque café est évalué selon des critères stricts pour garantir la meilleure expérience nomade.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-4 gap-6 max-w-5xl mx-auto">
            <div class="text-center p-6 rounded-lg border-2 border-border bg-card">
              <div class="text-3xl mb-3">🥉</div>
              <h3 class="font-semibold mb-2">Bronze</h3>
              <p class="text-sm text-muted-foreground">WiFi & Prises Basics</p>
            </div>

            <div class="text-center p-6 rounded-lg border-2 border-border bg-card">
              <div class="text-3xl mb-3">🥈</div>
              <h3 class="font-semibold mb-2">Silver</h3>
              <p class="text-sm text-muted-foreground">Horaires Étendus</p>
            </div>

            <div class="text-center p-6 rounded-lg border-2 border-border bg-card">
              <div class="text-3xl mb-3">🥇</div>
              <h3 class="font-semibold mb-2">Gold</h3>
              <p class="text-sm text-muted-foreground">Excellence Nomade</p>
            </div>

            <div class="text-center p-6 rounded-lg border-2 border-primary bg-primary/5">
              <div class="text-3xl mb-3">💎</div>
              <h3 class="font-semibold mb-2">Platinum</h3>
              <p class="text-sm text-muted-foreground">Premium + Events</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="py-20 bg-gradient-to-br from-primary via-ocean to-secondary relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('/pattern.svg')] opacity-10"></div>
        <div class="container mx-auto px-4 text-center relative z-10">
          <div class="max-w-2xl mx-auto space-y-6">
            <h2 class="text-3xl md:text-4xl font-bold text-white">
              Prêt à Rejoindre la Communauté ?
            </h2>
            <p class="text-lg text-white/90">
              Découvrez votre prochain spot de travail préféré et connectez-vous avec des nomades digitaux du Sénégal.
            </p>
            <a href="/cafes" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-white text-primary hover:bg-white/90 shadow-soft h-11 px-8 text-base">
              Commencer Maintenant <Zap class="ml-2 h-5 w-5" />
            </a>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-t bg-secondary text-secondary-foreground">
      <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="space-y-4">
            <div class="flex items-center gap-2">
              <span class="text-3xl">☕</span>
              <span class="text-lg font-bold">CaféNomad</span>
            </div>
            <p class="text-sm text-secondary-foreground/80">
              Votre guide pour trouver les meilleurs cafés de travail au Sénégal.
            </p>
          </div>

          <div>
            <h3 class="font-semibold mb-4">Navigation</h3>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="/" class="hover:text-primary transition-colors">Accueil</a>
              </li>
              <li>
                <a href="/cafes" class="hover:text-primary transition-colors">Explorer les Cafés</a>
              </li>
              <li>
                <a href="/about" class="hover:text-primary transition-colors">À Propos</a>
              </li>
            </ul>
          </div>

          <div>
            <h3 class="font-semibold mb-4">Villes</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center gap-2">
                <MapPin class="h-4 w-4 text-primary" />
                <span>Dakar</span>
              </li>
              <li class="flex items-center gap-2">
                <MapPin class="h-4 w-4 text-primary" />
                <span>Thiès</span>
              </li>
            </ul>
          </div>

          <div>
            <h3 class="font-semibold mb-4">Contact</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center gap-2">
                <span class="text-primary">✉</span>
                <span>contact@cafenomad.sn</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="mt-12 pt-8 border-t border-secondary-foreground/10 text-center text-sm">
          <p class="flex items-center justify-center gap-1">
            Fait avec <span class="text-primary">♥</span> pour les nomades digitaux du Sénégal
          </p>
          <p class="mt-2 text-secondary-foreground/60">© 2026 CaféNomad Sénégal. Tous droits réservés.</p>
        </div>
      </div>
    </footer>
  </div>
</Layout>
